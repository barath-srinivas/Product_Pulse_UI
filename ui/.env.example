# ─── Vercel (Production) ───────────────────────────────────────────────────────
# Set this in Vercel → Project → Settings → Environment Variables
# Use your Railway FastAPI URL (no trailing slash)
VITE_API_URL=https://your-pulse-api.up.railway.app

# ─── Local development only ──────────────────────────────────────────────────
# Where Vite proxies /api during `npm run dev` (pulse-api default port)
VITE_API_PROXY_TARGET=http://127.0.0.1:8000

# Leave VITE_API_URL empty locally — the app uses relative /api paths
# and Vite proxies them to VITE_API_PROXY_TARGET automatically.

# Vercel production only: set to false to hide Operator tab
# VITE_ENABLE_OPERATOR=false
